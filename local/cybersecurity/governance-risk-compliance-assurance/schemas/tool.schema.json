{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Tool Contract Manifest",
  "type": "object",
  "required": ["manifest_type", "id", "classification", "purpose", "permissions", "allowed_operations", "prohibited_operations"],
  "properties": {
    "manifest_type": { "const": "tool-contract" },
    "schema": { "type": "string" },
    "id": { "type": "string", "minLength": 1 },
    "classification": { "type": "string" },
    "purpose": { "type": "string", "minLength": 1 },
    "permissions": { "type": "object" },
    "allowed_operations": { "type": "array", "items": { "type": "string" } },
    "prohibited_operations": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}
