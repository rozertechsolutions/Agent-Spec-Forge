{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Workflow Manifest",
  "type": "object",
  "required": ["manifest_type", "id", "classification", "purpose", "owner", "steps", "outputs", "completion_criteria", "prohibited_actions"],
  "properties": {
    "manifest_type": { "const": "workflow" },
    "schema": { "type": "string" },
    "id": { "type": "string", "minLength": 1 },
    "classification": { "type": "string" },
    "purpose": { "type": "string", "minLength": 1 },
    "owner": { "type": "string" },
    "skills": { "type": "array", "items": { "type": "string" } },
    "steps": { "type": "array", "items": { "type": "string" } },
    "outputs": { "type": "array", "items": { "type": "string" } },
    "completion_criteria": { "type": "array", "items": { "type": "string" } },
    "human_review": { "type": "array", "items": { "type": "string" } },
    "prohibited_actions": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}
