{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Skill Manifest",
  "type": "object",
  "required": ["manifest_type", "id", "mission", "scope", "inputs", "outputs", "owner"],
  "properties": {
    "manifest_type": {"const": "skill"},
    "id": {"type": "string"},
    "mission": {"type": "string"},
    "scope": {"type": "array"},
    "inputs": {"type": "array"},
    "outputs": {"type": "array"},
    "owner": {"type": "string"}
  },
  "additionalProperties": true
}
