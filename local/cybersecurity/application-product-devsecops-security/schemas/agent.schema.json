{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent Manifest",
  "type": "object",
  "required": ["manifest_type", "id", "mission", "inputs", "outputs", "prohibited_actions"],
  "properties": {
    "manifest_type": {"const": "agent"},
    "id": {"type": "string"},
    "mission": {"type": "string"},
    "inputs": {"type": "array"},
    "outputs": {"type": "array"},
    "prohibited_actions": {"type": "array"}
  },
  "additionalProperties": true
}
