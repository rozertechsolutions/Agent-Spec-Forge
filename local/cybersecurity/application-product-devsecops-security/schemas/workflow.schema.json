{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Workflow Manifest",
  "type": "object",
  "required": ["manifest_type", "id", "purpose", "owner", "steps", "outputs"],
  "properties": {
    "manifest_type": {"const": "workflow"},
    "id": {"type": "string"},
    "purpose": {"type": "string"},
    "owner": {"type": "string"},
    "steps": {"type": "array"},
    "outputs": {"type": "array"}
  },
  "additionalProperties": true
}
