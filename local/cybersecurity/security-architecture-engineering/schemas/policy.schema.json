{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Policy Manifest",
  "type": "object",
  "required": ["manifest_type", "id", "classification"],
  "properties": {
    "manifest_type": { "const": "policy" },
    "schema": { "type": "string" },
    "id": { "type": "string", "minLength": 1 },
    "classification": { "type": "string" },
    "requirements": { "type": "array", "items": { "type": "string" } },
    "protected_material": { "type": "array", "items": { "type": "string" } },
    "default_permissions": { "type": "object" },
    "prohibited_actions": { "type": "array", "items": { "type": "string" } },
    "fail_safe_behavior": { "type": "string" }
  },
  "additionalProperties": true
}

