{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Local Specialization Manifest",
  "type": "object",
  "required": ["manifest_type", "id", "version", "surface", "status", "scope", "classification", "precedence", "delegation", "lifecycle", "validation"],
  "properties": {
    "manifest_type": { "const": "local-specialization" },
    "schema": { "type": "string" },
    "id": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "surface": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "minLength": 1 },
    "scope": { "type": "object" },
    "classification": { "type": "object" },
    "precedence": { "type": "array", "items": { "type": "string" } },
    "delegation": { "type": "object" },
    "capability_negotiation": { "type": "object" },
    "lifecycle": { "type": "object" },
    "validation": { "type": "object" },
    "references": { "type": "object" }
  },
  "additionalProperties": true
}

