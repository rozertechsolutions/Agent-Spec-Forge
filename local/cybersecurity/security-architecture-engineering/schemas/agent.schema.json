{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent Manifest",
  "type": "object",
  "required": ["manifest_type", "id", "classification", "mission", "exclusive_scope", "inputs", "outputs", "permissions", "prohibited_actions"],
  "properties": {
    "manifest_type": { "enum": ["agent", "coordinator"] },
    "schema": { "type": "string" },
    "id": { "type": "string", "minLength": 1 },
    "classification": { "type": "string" },
    "mission": { "type": "string", "minLength": 1 },
    "exclusive_scope": { "type": "array", "items": { "type": "string" } },
    "inputs": { "type": "array", "items": { "type": "string" } },
    "preconditions": { "type": "array", "items": { "type": "string" } },
    "outputs": { "type": "array", "items": { "type": "string" } },
    "evidence": { "type": "array", "items": { "type": "string" } },
    "tools": { "type": "array", "items": { "type": "string" } },
    "permissions": { "type": "object" },
    "dependencies": { "type": "array", "items": { "type": "string" } },
    "delegation": {},
    "stop_conditions": { "type": "array", "items": { "type": "string" } },
    "completion_criteria": { "type": "array", "items": { "type": "string" } },
    "human_review": { "type": "string" },
    "prohibited_actions": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}

