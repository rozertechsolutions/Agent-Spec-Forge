{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Local Engineering Configuration",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "provider",
    "model",
    "permissions"
  ],
  "properties": {
    "provider": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "baseUrl"
      ],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1
        },
        "baseUrl": {
          "type": "string",
          "format": "uri"
        },
        "apiKeyEnvironmentVariable": {
          "type": "string"
        },
        "requestTimeoutSeconds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 600
        }
      }
    },
    "model": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "temperature": {
          "type": "number",
          "minimum": 0,
          "maximum": 2
        },
        "maxOutputTokens": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "permissions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "network",
        "filesystemWrite",
        "externalWrite"
      ],
      "properties": {
        "network": {
          "type": "boolean",
          "default": false
        },
        "filesystemWrite": {
          "type": "boolean",
          "default": false
        },
        "externalWrite": {
          "type": "boolean",
          "const": false
        }
      }
    },
    "mcpServers": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "enabled"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "enabled": {
            "type": "boolean",
            "const": false
          },
          "transport": {
            "enum": [
              "stdio",
              "http"
            ]
          },
          "endpointEnvironmentVariable": {
            "type": "string"
          }
        }
      }
    }
  }
}
