{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Marketing Work Output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "state",
    "owner",
    "scope",
    "summary",
    "evidence",
    "assumptions",
    "risks",
    "reviewers",
    "nextHumanDecision"
  ],
  "properties": {
    "state": {
      "enum": [
        "draft",
        "blocked",
        "review_required",
        "ready_for_release_approval",
        "human_approved"
      ]
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "scope": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "reviewers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "nextHumanDecision": {
      "type": "string",
      "minLength": 1
    }
  }
}
