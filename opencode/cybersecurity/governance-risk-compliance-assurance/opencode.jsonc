{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "reference/NATIVE_SOURCES.md"
  ],
  "permission": {
    "read": "allow",
    "grep": "allow",
    "glob": "allow",
    "skill": "allow",
    "edit": "ask",
    "write": "ask",
    "apply_patch": "ask",
    "bash": "deny",
    "webfetch": "ask",
    "websearch": "ask",
    "mcp_*": "deny"
  },
  "mcp": {
    "governance_evidence": {
      "enabled": false,
      "type": "remote",
      "url": "https://example.invalid/mcp"
    }
  }
}
