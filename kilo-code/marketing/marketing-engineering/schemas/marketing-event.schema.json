{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/marketing/event.schema.json",
  "title": "Marketing Event Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "eventName",
    "eventVersion",
    "purpose",
    "consentCategory",
    "properties"
  ],
  "properties": {
    "eventName": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]{2,63}$"
    },
    "eventVersion": {
      "type": "integer",
      "minimum": 1
    },
    "purpose": {
      "type": "string",
      "minLength": 1
    },
    "consentCategory": {
      "enum": [
        "strictly_necessary",
        "analytics",
        "personalization",
        "advertising"
      ]
    },
    "properties": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "type",
          "required",
          "personalData"
        ],
        "properties": {
          "type": {
            "enum": [
              "string",
              "integer",
              "number",
              "boolean"
            ]
          },
          "required": {
            "type": "boolean"
          },
          "personalData": {
            "type": "boolean"
          },
          "description": {
            "type": "string"
          }
        }
      }
    }
  }
}
