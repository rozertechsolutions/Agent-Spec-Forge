{
  "$schema": "https://app.kilo.ai/config.json",
  "instructions": [
    ".kilo/rules/grc-scope.md",
    ".kilo/rules/grc-security-baseline.md",
    ".kilo/rules/grc-evidence-and-approval.md",
    ".kilo/rules/grc-responsibility-matrix.md"
  ],
  "permission": {
    "read": {
      "*": "allow",
      "*.env": "ask",
      "*.env.*": "ask",
      "*.env.example": "allow",
      "*secret*": "ask",
      "*credential*": "ask",
      "*private-key*": "ask"
    },
    "edit": {
      "*": "ask",
      "../*": "deny",
      "/**": "deny"
    },
    "write": {
      "*": "ask",
      "../*": "deny",
      "/**": "deny"
    },
    "bash": {
      "*": "ask",
      "git status *": "allow",
      "git diff *": "allow",
      "rg *": "allow",
      "find *": "allow",
      "ls *": "allow",
      "cat *": "allow",
      "sed *": "allow",
      "git commit *": "deny",
      "git push *": "deny",
      "git pull *": "deny",
      "git merge *": "deny",
      "git rebase *": "deny",
      "git reset *": "deny",
      "git clean *": "deny",
      "git checkout *": "deny",
      "git restore *": "deny",
      "git switch *": "deny",
      "git branch *": "deny",
      "rm *": "deny",
      "rmdir *": "deny"
    },
    "task": {
      "*": "deny",
      "governance-policy-frameworks-agent": "allow",
      "cyber-risk-exceptions-agent": "allow",
      "assurance-evidence-remediation-agent": "allow",
      "third-party-maturity-reporting-agent": "allow",
      "independent-assurance-reviewer": "allow"
    }
  },
  "mcp": {}
}
