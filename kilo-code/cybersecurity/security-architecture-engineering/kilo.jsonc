{
  "$schema": "https://app.kilo.ai/config.json",
  "instructions": [
    ".kilo/rules/security-architecture-scope.md",
    ".kilo/rules/security-architecture-baseline.md",
    ".kilo/rules/evidence-and-approval.md",
    ".kilo/rules/responsibility-matrix.md"
  ],
  "permission": {
    "read": {
      "*": "allow",
      "*.env": "ask",
      "*.env.*": "ask",
      "*.env.example": "allow",
      "*secret*": "ask",
      "*credential*": "ask",
      "*private-key*": "ask"
    },
    "edit": {
      "*": "ask",
      "../*": "deny",
      "/**": "deny"
    },
    "write": {
      "*": "ask",
      "../*": "deny",
      "/**": "deny"
    },
    "bash": {
      "*": "ask",
      "git status *": "allow",
      "git diff *": "allow",
      "rg *": "allow",
      "find *": "allow",
      "ls *": "allow",
      "cat *": "allow",
      "sed *": "allow",
      "git commit *": "deny",
      "git push *": "deny",
      "git pull *": "deny",
      "git merge *": "deny",
      "git rebase *": "deny",
      "git reset *": "deny",
      "git clean *": "deny",
      "git checkout *": "deny",
      "git restore *": "deny",
      "git switch *": "deny",
      "git branch *": "deny",
      "rm *": "deny",
      "rmdir *": "deny"
    },
    "task": {
      "*": "deny",
      "architecture-governance-agent": "allow",
      "enterprise-solution-architecture-agent": "allow",
      "identity-cloud-network-agent": "allow",
      "data-container-automation-agent": "allow",
      "independent-architecture-reviewer": "allow"
    }
  },
  "mcp": {}
}
