{
  "$schema": "https://app.kilo.ai/config.json",
  "instructions": [],
  "permission": {
    "read": {
      "*": "allow",
      "*.env": "ask",
      "*.env.*": "ask",
      "*.env.example": "allow",
      "*secret*": "ask",
      "*credential*": "ask",
      "*private-key*": "ask"
    },
    "edit": {
      "*": "ask",
      "../*": "deny",
      "/**": "deny"
    },
    "write": {
      "*": "ask",
      "../*": "deny",
      "/**": "deny"
    },
    "bash": {
      "*": "deny",
      "git status *": "allow",
      "git diff *": "allow",
      "rg *": "allow",
      "find *": "allow",
      "ls *": "allow",
      "cat *": "allow",
      "sed *": "allow",
      "git commit *": "deny",
      "git push *": "deny",
      "git pull *": "deny",
      "git merge *": "deny",
      "git rebase *": "deny",
      "git reset *": "deny",
      "git clean *": "deny",
      "git checkout *": "deny",
      "git restore *": "deny",
      "git switch *": "deny",
      "git branch *": "deny",
      "rm *": "deny",
      "rmdir *": "deny"
    },
    "task": {
      "*": "deny",
      "forensics-containment-recovery-agent": "allow",
      "incident-command-evidence-agent": "allow",
      "independent-incident-recovery-reviewer": "allow",
      "post-incident-corrective-action-agent": "allow",
      "scenario-crisis-review-agent": "allow"
    }
  },
  "mcp": {}
}
