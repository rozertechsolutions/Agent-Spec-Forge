{
  "permissions": {
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push:*)",
      "Bash(git commit:*)",
      "Bash(git reset --hard:*)",
      "Bash(npm publish:*)",
      "Bash(docker push:*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./**/*secret*)",
      "Read(./**/*credential*)",
      "Read(./**/*.pem)",
      "Read(./**/*.key)"
    ]
  }
}
