{
  "mcpServers": {
    "firebase": {
      "type": "stdio",
      "command": "${FIREBASE_CLI:-firebase}",
      "args": [
        "mcp",
        "--only",
        "auth,firestore,storage,crashlytics"
      ]
    },
    "figma": {
      "type": "http",
      "url": "https://mcp.figma.com/mcp"
    },
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer ${GITHUB_PERSONAL_ACCESS_TOKEN}",
        "X-MCP-Toolsets": "repos,pull_requests",
        "X-MCP-Readonly": "true",
        "X-MCP-Lockdown": "true"
      }
    },
    "sentry": {
      "type": "http",
      "url": "https://mcp.sentry.dev/mcp"
    }
  }
}
