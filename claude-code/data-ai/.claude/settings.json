{
  "disableClaudeAiConnectors": true,
  "disableSkillShellExecution": true,
  "permissions": {
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push:*)",
      "Bash(git reset --hard:*)",
      "Bash(git rebase:*)",
      "Bash(npm publish:*)",
      "Bash(docker push:*)",
      "Bash(kubectl apply:*)",
      "Bash(terraform apply:*)",
      "Bash(aws *:*)",
      "Bash(gcloud *:*)",
      "Bash(az *:*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./**/*secret*)",
      "Read(./**/*credential*)",
      "Read(./**/*.pem)",
      "Read(./**/*.key)"
    ]
  }
}
